# ============================================================
# Aegis Monorepo .gitignore
# Covers: Node.js, Next.js/React, Python, Edge/Serverless
# ============================================================

# Node.js / JavaScript / TypeScript
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js

# Next.js
.next/
out/

# Vite / React
dist/
build/

# TypeScript
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
venv/
.venv/
env/
.env.local
.env.*.local
pip-log.txt
pip-delete-this-directory.txt

# Edge / Serverless (Cloudflare Workers, Wrangler)
.wrangler/
.dev.vars
worker-configuration.d.ts

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Environment / Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
coverage/
.nyc_output/
.pytest_cache/
htmlcov/

# Misc
*.log
*.tgz
.cache/
